{
  "name": "galaxy-classification-app",
  "private": true,
  "version": "0.2.31",
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "vite",
    "dev:frontend:host": "vite --host 0.0.0.0",
    "dev:backend": "convex dev",
    "dev:images": "dotenv -e .env.local -- node scripts/local-image-server.mjs",
    "dev:all": "npm-run-all --parallel dev:frontend dev:backend dev:images",
    "dev:all:hosts": "npm-run-all --parallel dev:frontend:host dev:backend dev:images",
    "build": "vite build",
    "lint": "tsc -p convex -noEmit --pretty false && tsc -p . -noEmit --pretty false && convex dev --once && vite build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@convex-dev/aggregate": "^0.2.1",
    "@convex-dev/auth": "^0.0.91",
    "@react-email/render": "^2.0.4",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "node-fetch": "^3.3.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-email": "^5.2.9",
    "react-router": "^7.13.1",
    "recharts": "^3.7.0",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "~10",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "npm-run-all": "^4.1.5",
    "postcss": "~8",
    "prettier": "^3.8.1",
    "tailwindcss": "~3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
