{
    "headers": [
        {
            "source": "/((?!assets/|favicon\\.ico|og-preview\\.png).*)",
            "headers": [
                { "key": "Cache-Control", "value": "no-cache" }
            ]
        }
    ],
    "rewrites": [
        { "source": "/((?!assets/|favicon\\.ico|og-preview\\.png).*)", "destination": "/index.html" }
    ]
}
